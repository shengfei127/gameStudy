{
  "name": "game-study-uniapp",
  "version": "0.1.0",
  "private": true,
  "description": "A uni-app Vue 3 TypeScript Android starter.",
  "scripts": {
    "dev:h5": "uni",
    "dev:custom": "uni -p",
    "dev:mp-weixin": "uni -p mp-weixin",
    "build:h5": "uni build",
    "build:app-plus": "uni build -p app-plus",
    "build:android": "npm run build:app-plus",
    "build:custom": "uni build -p",
    "build:mp-weixin": "uni build -p mp-weixin",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "deploy:updates": "npx wrangler pages deploy updates --project-name=study-pet-updates --force"
  },
